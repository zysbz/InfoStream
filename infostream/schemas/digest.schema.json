{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infostream.local/schemas/digest.schema.json",
  "title": "InfoStream Digest",
  "type": "object",
  "required": ["generated_at", "language", "total", "items"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "language": { "type": "string" },
    "total": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "title",
          "one_liner",
          "bullets",
          "tags",
          "source_url",
          "local_path"
        ],
        "properties": {
          "item_id": { "type": "string" },
          "title": { "type": "string" },
          "one_liner": { "type": "string" },
          "bullets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "why_it_matters": { "type": ["string", "null"] },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source_url": { "type": "string" },
          "local_path": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}